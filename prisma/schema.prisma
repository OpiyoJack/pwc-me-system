generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                  Int        @id @default(autoincrement())
  name                String
  email               String     @unique
  password            String
  role                String     @default("coordinator")
  active              Boolean    @default(true)
  permissions         String     @default("")
  mustChangePassword  Boolean    @default(false)
  mfaEnabled          Boolean    @default(false)
  mfaSecret           String?
  phone               String?
  createdAt           DateTime   @default(now())
  assignedFeedback    Feedback[] @relation("FeedbackAssignee")
  coordinatedProjects Project[]  @relation("ProjectCoordinator")
  donorProjects       Project[]  @relation("ProjectDonorContact")
  ownedRisks          Risk[]     @relation("RiskOwner")
}

model Project {
  id             Int             @id @default(autoincrement())
  name           String
  sector         String
  district       String
  status         String          @default("Ongoing")
  budget         Float?
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime        @default(now())
  coordinatorId  Int?
  donorContactId Int?
  beneficiaries  Beneficiary[]
  feedbacks      Feedback[]
  frameworkNodes FrameworkNode[]
  indicators     Indicator[]
  members        Member[]
  coordinator    User?           @relation("ProjectCoordinator", fields: [coordinatorId], references: [id])
  donorContact   User?           @relation("ProjectDonorContact", fields: [donorContactId], references: [id])
  risks          Risk[]
}

model Indicator {
  id              Int               @id @default(autoincrement())
  name            String
  target          Float
  actual          Float             @default(0)
  unit            String
  projectId       Int
  frameworkNodeId Int?
  formula       IndicatorFormula?
  frameworkNode   FrameworkNode?    @relation(fields: [frameworkNodeId], references: [id])
  project         Project           @relation(fields: [projectId], references: [id])
  updates         IndicatorUpdate[]
}

model FrameworkNode {
  id          Int             @id @default(autoincrement())
  projectId   Int
  levelLabel  String
  title       String
  description String?
  order       Int             @default(0)
  parentId    Int?
  createdAt   DateTime        @default(now())
  parent      FrameworkNode?  @relation("NodeChildren", fields: [parentId], references: [id])
  children    FrameworkNode[] @relation("NodeChildren")
  project     Project         @relation(fields: [projectId], references: [id])
  indicators  Indicator[]
}

model Beneficiary {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  sex       String
  age       Int
  district  String
  sector    String
  enrolled  DateTime @default(now())
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])
}

model Member {
  id        Int      @id @default(autoincrement())
  name      String
  village   String
  district  String
  status    String   @default("Pending")
  joined    DateTime @default(now())
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])
}

model Feedback {
  id         Int      @id @default(autoincrement())
  category   String
  district   String
  note       String
  status     String   @default("Open")
  createdAt  DateTime @default(now())
  projectId  Int?
  assigneeId Int?
  assignee   User?    @relation("FeedbackAssignee", fields: [assigneeId], references: [id])
  project    Project? @relation(fields: [projectId], references: [id])
}

model IndicatorUpdate {
  id          Int       @id @default(autoincrement())
  indicatorId Int
  newActual   Float
  note        String?
  createdAt   DateTime  @default(now())
  indicator   Indicator @relation(fields: [indicatorId], references: [id])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userName  String
  userEmail String?
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model DeletionLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityName String
  reason     String
  deletedBy  String
  deletedAt  DateTime @default(now())
}

model ReportRequest {
  id              Int       @id @default(autoincrement())
  reportType      String    @default("programme_summary")
  name            String    @default("PWC M&E Results Report")
  description     String    @default("A comprehensive summary of project results, beneficiaries, and feedback for the selected period and scope.")
  requestedByName String
  requestedById   Int?
  startDate       DateTime?
  endDate         DateTime?
  projectId       Int?
  projectName     String?
  status          String    @default("Processing")
  createdAt       DateTime  @default(now())
  finishedAt      DateTime?
}

model Risk {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  likelihood  String   @default("Medium")
  impact      String   @default("Medium")
  mitigation  String?
  status      String   @default("Open")
  createdAt   DateTime @default(now())
  projectId   Int?
  ownerId     Int?
  owner       User?    @relation("RiskOwner", fields: [ownerId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
}

model IndicatorFormula {
  id          Int       @id @default(autoincrement())
  indicator   Indicator @relation(fields: [indicatorId], references: [id])
  indicatorId Int       @unique
  field       String
  operator    String
  value       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
